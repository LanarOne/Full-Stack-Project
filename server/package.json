{
  "name": "server",
  "version": "1.0.0",
  "description": "Backend of the app",
  "homepage": "https://github.com/TuringCollegeSubmissions/nasimon-WD2.3.4.5#readme",
  "bugs": {
    "url": "https://github.com/TuringCollegeSubmissions/nasimon-WD2.3.4.5/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TuringCollegeSubmissions/nasimon-WD2.3.4.5.git"
  },
  "license": "ISC",
  "author": "n4n",
  "type": "module",
  "main": "index.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json && npx tsc-alias",
    "clean": "rm -rf node_modules package-lock.json dist",
    "coverage": "vitest run --coverage",
    "dev": "tsx watch src",
    "format": "prettier --write \"src/**/*/ts\"",
    "gen:types": "kysely-codegen --camel-case --dialect postgres --out-file src/database/types.ts && prettier --write src/database/types.ts",
    "lint": "eslint ./src --ext .js,.jsx,.ts,np.tsx --fix",
    "migrate:latest": "tsx ./src/database/migrate/latest",
    "migrate:latest:prod": "npm run node-es dist/database/migrate/latest.js",
    "migrate:new": "tsx ./src/database/migrate/new",
    "node-es": "node --import 'data:text/javascript, import { register } from \"node:module\"; import { pathToFileURL } from \"node:url\"; register(\"./loader.js\", pathToFileURL(\"./\"));'",
    "prod": "npm run migrate:latest:prod && npm run start",
    "start": "npm run node-es ./dist/index.js",
    "start:again": "node ./dist/index.js",
    "test": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tsconfig/node20": "^20.1.8",
    "@types/bcrypt": "^6.0.0",
    "@types/chance": "^1.1.7",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.0.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitest/coverage-v8": "^4.0.16",
    "bcrypt": "^6.0.0",
    "chance": "^1.1.13",
    "eslint": "^8.57.1",
    "eslint-config-airbnb": "^19.0.4",
    "eslint-config-airbnb-typescript": "^18.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "kysely-codegen": "^0.19.0",
    "prettier": "^3.7.4",
    "supertest": "^7.1.4",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.16"
  },
  "dependencies": {
    "@trpc/server": "^11.8.1",
    "@types/lodash-es": "^4.17.12",
    "copy-anything": "^4.0.5",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "kysely": "^0.28.9",
    "lodash": "^4.17.21",
    "pg": "^8.16.3",
    "superjson": "^2.2.6",
    "trpc-panel": "^1.3.4",
    "zod": "^3.25.76",
    "zod-validation-error": "^5.0.0"
  }
}
